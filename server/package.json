{
  "name": "server",
  "version": "1.0.0",
  "description": "Bahar Task Management Server",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "cross-env NODE_ENV=development nodemon src/server.js",
    "build": "npx pkg . --assets \"dist/**/*\" --targets node18-win-x64 --output release/bahar.exe",
    "backfill": "cross-env NODE_ENV=production node src/scripts/backfill.js --mode=encrypt --batch=500",
    "backfill:dry": "cross-env NODE_ENV=production node src/scripts/backfill.js --mode=encrypt --batch=100 --dry-run",
    "backfill:rollback": "cross-env NODE_ENV=production node src/scripts/backfill.js --mode=rollback",
    "backfill:dev": "cross-env NODE_ENV=development node src/scripts/backfill.js --mode=encrypt --batch=500",
    "backfill:dry:dev": "cross-env NODE_ENV=development node src/scripts/backfill.js --mode=encrypt --batch=100 --dry-run",
    "backfill:rollback:dev": "cross-env NODE_ENV=development node src/scripts/backfill.js --mode=rollback",
    "build:backfill": "npx pkg src/scripts/backfill.js --targets node18-win-x64 --output release/bahar-backfill.exe"
  },
  "pkg": {
    "assets": "dist/**/*",
    "targets": "node18-win-x64",
    "outputPath": "release",
    "scripts": "src/**/*.js",
    "dependencies": true
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mssql": "^10.0.2",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0",
    "pkg": "^5.8.1"
  }
}
